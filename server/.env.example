# ==========================================
# 童话故事平台 - 环境变量参考
# 部署到 Render 时，在 Environment Variables 中填写以下变量
# ==========================================

# 服务端口（Render 会自动注入 PORT，无需手动设置）
PORT=3001

# JWT 签名密钥（务必使用随机生成的强密钥！）
JWT_SECRET=your-super-secret-random-key-change-me

# ===== 数据库（Prisma 会按 DATABASE_URL 自动切换 schema 与迁移目录） =====
# 本地开发使用 SQLite：file:./dev.db
# Render 生产环境使用 PostgreSQL（由 Render PostgreSQL 服务自动提供）
DATABASE_URL=file:./dev.db

# 运行环境（本地 development，Render 自动设为 production）
NODE_ENV=development

# GLM 大模型 API Key（智谱开放平台）
GLM_API_KEY=your-glm-api-key
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7
